generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String           @unique @db.VarChar(255)
  passwordHash    String           @map("password_hash") @db.VarChar(255)
  name            String           @db.VarChar(255)
  phone           String?          @db.VarChar(20)
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime?        @default(now()) @map("updated_at") @db.Timestamp(6)
  
  vehicles        Vehicle[]
  emergencyAlerts EmergencyAlert[]
  trips           Trip[]
  appointments    Appointment[]
  alerts          Alert[]

  @@map("users")
}

model Vehicle {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?       @map("user_id") @db.Uuid
  plateNumber    String        @map("plate_number") @db.VarChar(20)
  model          String        @db.VarChar(100)
  year           Int
  color          String?       @db.VarChar(50)
  nextInspection DateTime?     @map("next_inspection") @db.Date
  createdAt      DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  devices        Device[]
  trips          Trip[]
  appointments   Appointment[]

  @@index([userId], map: "idx_vehicles_user_id")
  @@map("vehicles")
}

model EmergencyAlert {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String?   @map("user_id") @db.Uuid
  locationLat      Decimal   @map("location_lat") @db.Decimal(10, 8)
  locationLng      Decimal   @map("location_lng") @db.Decimal(11, 8)
  locationAccuracy Decimal?  @map("location_accuracy") @db.Decimal(8, 2)
  timestamp        DateTime? @default(now()) @db.Timestamp(6)
  type             String    @db.VarChar(50) // 'accident', 'brake_failure', 'other'
  severity         String    @db.VarChar(20) // 'low', 'medium', 'high'
  status           String?   @default("active") @db.VarChar(20) // 'active', 'resolved', 'false_alarm'
  
  user             User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([timestamp], map: "idx_emergency_alerts_timestamp")
  @@index([userId], map: "idx_emergency_alerts_user_id")
  @@map("emergency_alerts")
}

model Trip {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?   @map("user_id") @db.Uuid
  vehicleId       String?   @map("vehicle_id") @db.Uuid
  startTime       DateTime? @default(now()) @map("start_time") @db.Timestamp(6)
  endTime         DateTime? @map("end_time") @db.Timestamp(6)
  startLat        Decimal?  @map("start_lat") @db.Decimal(10, 8)
  startLng        Decimal?  @map("start_lng") @db.Decimal(11, 8)
  endLat          Decimal?  @map("end_lat") @db.Decimal(10, 8)
  endLng          Decimal?  @map("end_lng") @db.Decimal(11, 8)
  distanceKm      Decimal?  @map("distance_km") @db.Decimal(8, 2)
  durationMinutes Int?      @map("duration_minutes")
  status          String?   @default("ongoing") @db.VarChar(20) // 'ongoing', 'completed', 'cancelled'
  
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle         Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_trips_user_id")
  @@index([vehicleId], map: "idx_trips_vehicle_id")
  @@map("trips")
}

model Appointment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  vehicleId       String?  @map("vehicle_id") @db.Uuid
  type            String   @db.VarChar(50) // 'inspection', 'maintenance', 'repair'
  scheduledDate   DateTime @map("scheduled_date") @db.Timestamp(6)
  durationMinutes Int      @map("duration_minutes")
  status          String?  @default("scheduled") @db.VarChar(20) // 'scheduled', 'completed', 'cancelled', 'rescheduled'
  notes           String?
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle         Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_appointments_user_id")
  @@index([vehicleId], map: "idx_appointments_vehicle_id")
  @@map("appointments")
}

model Alert {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  title     String    @db.VarChar(255)
  message   String
  type      String    @db.VarChar(20) // 'info', 'warning', 'error', 'success'
  timestamp DateTime? @default(now()) @db.Timestamp(6)
  read      Boolean?  @default(false)
  actionUrl String?   @map("action_url") @db.VarChar(500)
  
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([read], map: "idx_alerts_read")
  @@index([userId], map: "idx_alerts_user_id")
  @@map("alerts")
}

// ----- Legacy Keep (IoT Integration) -----
model Device {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId  String?      @map("vehicle_id") @db.Uuid
  vehicle    Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  macAddress String       @unique @map("mac_address")
  sensorData SensorData[]

  @@map("devices")
}

model SensorData {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId    String?  @map("device_id") @db.Uuid
  device      Device?  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  temperature Float?
  humidity    Float?
  timestamp   DateTime @default(now())

  @@map("sensor_data")
}
